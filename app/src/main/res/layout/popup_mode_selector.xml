<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/mode_selector_width"
    android:layout_height="wrap_content"
    android:background="@drawable/popup_bg"
    android:orientation="vertical"
    android:padding="8dp">

    <TextView
        android:id="@+id/basicModeItem"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mode_selector_item_height"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/mode_basic"
        android:textColor="@color/mode_selector_text"
        android:textSize="16sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/history_divider" />

    <TextView
        android:id="@+id/scientificModeItem"
        android:layout_width="match_parent"
        android:layout_height="@dimen/mode_selector_item_height"
        android:background="?attr/selectableItemBackground"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/mode_scientific"
        android:textColor="@color/mode_selector_text"
        android:textSize="16sp" />

</LinearLayout>
